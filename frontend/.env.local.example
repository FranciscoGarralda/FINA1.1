# Copiá este archivo a .env.local (desde la carpeta frontend/) y reemplazá la URL.
# Valor: URL absoluta pública del API (Railway) que termina en /api, sin barra final después de /api.
# Alineado con frontend/src/api/client.ts y frontend/.env.example.
#
#   cp .env.local.example .env.local
#   # editá VITE_API_BASE con tu URL real
#   npm run dev
#
VITE_API_BASE=https://REEMPLAZA-POR-TU-API.up.railway.app/api
