# Copiá a backend/.env (gitignored) y completá.

# --- Base de datos ---
# Opción A — Postgres local (docker compose en la raíz, usuario fina/fina):
#   No definir DATABASE_URL → el API usa postgres://fina:fina@localhost:5432/fina?sslmode=disable
#
# Opción B — Supabase / Railway / otra nube:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
#
# DATABASE_URL=

# Tamaño del pool pgx por proceso. Debe ser bajo respecto al límite de conexiones
# del plan de Postgres en Railway (y sumar todas las réplicas del API).
POOL_MAX_CONNS=5

JWT_SECRET=dev-secret-change-me
PORT=8080
